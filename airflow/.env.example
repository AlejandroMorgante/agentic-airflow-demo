AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
AWS_PROFILE=snail-data
AWS_REGION=us-east-1

# Airflow Variables injected from env.
# Airflow exposes AIRFLOW_VAR_FOO as {{ var.value.FOO }}.
AIRFLOW_VAR_AGENT_CONTAINER_URI=471112687668.dkr.ecr.us-east-1.amazonaws.com/agentic-airflow-agent:payload-context
AIRFLOW_VAR_AGENTCORE_RUNTIME_NAME=airflow_troubleshooter_haiku
AIRFLOW_VAR_AGENTCORE_EXECUTION_ROLE_ARN=
AIRFLOW_VAR_AGENT_RUNTIME_ARN=
AIRFLOW_VAR_AGENT_RUNTIME_ID=

# Runtime env vars passed to the AgentCore container by agentcore_create_runtime.
AIRFLOW_VAR_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
AIRFLOW_VAR_GITHUB_REPO=AlejandroMorgante/agentic-airflow-poc
AIRFLOW_VAR_GITHUB_REF=main
AIRFLOW_VAR_GITHUB_DAG_PATH=airflow/dags
AIRFLOW_VAR_GITHUB_TOKEN=
AIRFLOW_VAR_SLACK_WEBHOOK_URL=
