# Security note: this PoC passes some runtime secrets as environment variables.
# Do not commit real values. For production, use a managed secret store
# such as AWS Secrets Manager or Google Secret Manager instead.

AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
AWS_PROFILE=default
AWS_REGION=us-east-1
AIRFLOW_GOOGLE_PROVIDER_SRC=../../../airflow/providers/google/src

# Airflow Variables injected from env.
# Airflow exposes AIRFLOW_VAR_FOO as {{ var.value.FOO }}.
AIRFLOW_VAR_AGENT_CONTAINER_URI=<AWS_ACCOUNT_ID>.dkr.ecr.<AWS_REGION>.amazonaws.com/agentic-airflow-agent:payload-context
AIRFLOW_VAR_AGENTCORE_RUNTIME_NAME=airflow_troubleshooter_haiku
AIRFLOW_VAR_AGENTCORE_EXECUTION_ROLE_ARN=
AIRFLOW_VAR_AGENT_RUNTIME_ARN=
AIRFLOW_VAR_AGENT_RUNTIME_ID=

# GCP / Vertex AI Agent Engine
AIRFLOW_VAR_GCP_PROJECT_ID=<GCP_PROJECT_ID>
AIRFLOW_VAR_GCP_REGION=us-central1
AIRFLOW_VAR_GCP_AGENT_ENGINE_CONTAINER_URI=<GCP_REGION>-docker.pkg.dev/<GCP_PROJECT_ID>/<GCP_REPOSITORY>/airflow-troubleshooting-agent:<TAG>
AIRFLOW_VAR_GCP_AGENT_ENGINE_QUERY_OUTPUT_GCS_URI=gs://<GCP_PROJECT_ID>-agent-engine-query-output/query-output/
# Set this only when running standalone get/query/update/delete Dags.
# Leave it unset when using gcp_agentengine_full_lifecycle.
# AIRFLOW_VAR_GCP_AGENT_ENGINE_NAME=projects/<GCP_PROJECT_ID>/locations/<GCP_REGION>/reasoningEngines/<AGENT_ENGINE_ID>
AIRFLOW_VAR_GCP_AGENT_ENGINE_DISPLAY_NAME=airflow-agent-engine
AIRFLOW_VAR_GEMINI_MODEL_ID=gemini-2.5-pro

# Uses Application Default Credentials mounted from ~/.config/gcloud.
# This connection URI contains no key material.
AIRFLOW_CONN_GOOGLE_CLOUD_DEFAULT=google-cloud-platform://?extra__google_cloud_platform__project=<GCP_PROJECT_ID>&extra__google_cloud_platform__scope=https%3A%2F%2Fwww.googleapis.com%2Fauth%2Fcloud-platform

# Microsoft Azure AI Foundry Agents
AIRFLOW_VAR_AZURE_AI_AGENTS_MODEL=gpt-4o
AIRFLOW_VAR_AZURE_AI_AGENT_NAME=airflow-troubleshooting-agent
# Azure Storage Queue endpoint for Azure Function tools (e.g. https://<account>.queue.core.windows.net)
AIRFLOW_VAR_AZURE_STORAGE_QUEUE_ENDPOINT=https://<storage-account>.queue.core.windows.net
# Set this only when running standalone update/run/delete Dags and demos.
# Leave it unset when using azure_ai_agents_full_lifecycle.
# AIRFLOW_VAR_AZURE_AI_AGENT_ID=<AZURE_AI_AGENT_ID>
# Optional overrides. By default, operators use azure_ai_agents_default.
# AIRFLOW_VAR_AZURE_AI_AGENTS_CONN_ID=azure_ai_agents_default
# AIRFLOW_VAR_AZURE_AI_AGENTS_ENDPOINT=https://<aiservices-id>.services.ai.azure.com/api/projects/<project-name>
# AIRFLOW_CONN_AZURE_AI_AGENTS_DEFAULT=azure-ai-agents://<client-id>:<client-secret>@<url-encoded-endpoint>?tenantId=<tenant-id>

# Runtime env vars passed to the AgentCore container by agentcore_create_runtime.
AIRFLOW_VAR_BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
AIRFLOW_VAR_GITHUB_REPO=owner/repo
AIRFLOW_VAR_GITHUB_REF=main
AIRFLOW_VAR_GITHUB_DAG_PATH=airflow/dags
AIRFLOW_VAR_GITHUB_TOKEN=
AIRFLOW_VAR_SLACK_WEBHOOK_URL=
